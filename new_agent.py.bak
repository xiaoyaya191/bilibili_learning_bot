    while True:
        vision_has_independent = bool(config["api"].get("vision_api_key", ""))
        vision_key_display = mask_secret(VISION_API_KEY)
        vision_url_display = VISION_BASE_URL
        vision_tag = " 独立" if vision_has_independent else " 共用统一"
        
        print(f"""
